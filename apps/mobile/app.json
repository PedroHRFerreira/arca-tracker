{
  "expo": {
    "name": "ARCA Tracker",
    "slug": "arca-tracker",
    "owner": "pedrohrferreira",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "arcatracker",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.pedro.arcatracker",
      "infoPlist": {
        "UIBackgroundModes": [
          "processing"
        ],
        "BGTaskSchedulerPermittedIdentifiers": [
          "com.expo.modules.backgroundtask.processing"
        ]
      }
    },
    "android": {
      "package": "com.pedro.arcatracker",
      "adaptiveIcon": {
        "backgroundColor": "#F5F7FB"
      }
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-notifications",
      "expo-sqlite",
      "expo-background-task"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "8798be59-54af-44a9-af90-3488d6ace355"
      }
    }
  }
}
